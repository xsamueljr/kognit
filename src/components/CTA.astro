---
---

<section id="contacto" class="py-20 md:py-28 lg:py-32 border-t border-white/[0.06] relative">
  <!-- Glowing back-effect for visual magic -->
  <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[350px] sm:w-[600px] h-[350px] bg-brand-indigo/5 blur-[120px] rounded-full pointer-events-none -z-10" aria-hidden="true"></div>

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
    
    <!-- Left Column: Copy & Direct Info -->
    <div class="lg:col-span-5">
      <div class="text-xs font-semibold text-brand-violet uppercase tracking-wider mb-3 font-display">Comienza hoy</div>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight text-white mb-6 leading-tight font-display">
        ¿Listo para acelerar tu transformación?
      </h2>
      <p class="text-zinc-400 text-base leading-relaxed mb-8">
        Hablemos de tus flujos de trabajo actuales. Analizamos tus procesos de forma gratuita para diseñar un prototipo de automatización a la medida de tus necesidades comerciales.
      </p>

      <div class="space-y-4 border-t border-white/[0.06] pt-8">
        <div class="flex items-center gap-3">
          <svg class="h-5 w-5 text-brand-violet" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
          <span class="text-sm text-zinc-300 font-mono">contacto@kognit.ai</span>
        </div>
        <div class="flex items-center gap-3">
          <svg class="h-5 w-5 text-brand-violet" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25s-7.5-4.108-7.5-11.25g" />
          </svg>
          <span class="text-sm text-zinc-300">Madrid, España — Soporte Global</span>
        </div>
      </div>
    </div>

    <!-- Right Column: Interactive Minimal Form -->
    <div class="lg:col-span-7">
      <div class="relative border border-white/[0.08] bg-zinc-950/80 backdrop-blur-md rounded-2xl p-6 sm:p-10 shadow-2xl">
        <form class="space-y-6" id="contact-form">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label for="name" class="block text-xs font-semibold text-zinc-400 uppercase tracking-wider mb-2 font-display">Nombre completo</label>
              <input 
                type="text" 
                id="name" 
                required 
                placeholder="Juan Pérez" 
                class="w-full bg-black border border-zinc-800 rounded-lg px-4 py-3 text-sm text-white placeholder-zinc-600 focus:outline-none focus:border-brand-violet/50 focus:ring-1 focus:ring-brand-violet/30 transition-all duration-300"
              />
            </div>
            <div>
              <label for="email" class="block text-xs font-semibold text-zinc-400 uppercase tracking-wider mb-2 font-display">Correo Electrónico</label>
              <input 
                type="email" 
                id="email" 
                required 
                placeholder="juan@empresa.com" 
                class="w-full bg-black border border-zinc-800 rounded-lg px-4 py-3 text-sm text-white placeholder-zinc-600 focus:outline-none focus:border-brand-violet/50 focus:ring-1 focus:ring-brand-violet/30 transition-all duration-300"
              />
            </div>
          </div>
          
          <div>
            <label for="company" class="block text-xs font-semibold text-zinc-400 uppercase tracking-wider mb-2 font-display">Nombre de la Empresa</label>
            <input 
              type="text" 
              id="company" 
              placeholder="Mi Empresa S.L." 
              class="w-full bg-black border border-zinc-800 rounded-lg px-4 py-3 text-sm text-white placeholder-zinc-600 focus:outline-none focus:border-brand-violet/50 focus:ring-1 focus:ring-brand-violet/30 transition-all duration-300"
            />
          </div>

          <div>
            <label for="message" class="block text-xs font-semibold text-zinc-400 uppercase tracking-wider mb-2 font-display">¿Cómo podemos ayudarte?</label>
            <textarea 
              id="message" 
              rows="4" 
              required 
              placeholder="Descríbenos brevemente los procesos o flujos de trabajo que deseas automatizar o digitalizar..." 
              class="w-full bg-black border border-zinc-800 rounded-lg px-4 py-3 text-sm text-white placeholder-zinc-600 focus:outline-none focus:border-brand-violet/50 focus:ring-1 focus:ring-brand-violet/30 transition-all duration-300 resize-none"
            ></textarea>
          </div>

          <button 
            type="submit" 
            class="w-full py-4 px-6 text-sm font-semibold text-white bg-gradient-to-r from-brand-indigo to-brand-violet rounded-lg hover:from-brand-indigo/90 hover:to-brand-violet/90 active:scale-98 transition-all duration-300 shadow-[0_0_20px_rgba(139,92,246,0.15)] cursor-pointer"
          >
            Enviar Solicitud de Consulta &rarr;
          </button>
        </form>
        
        <!-- Feedback success modal mockup -->
        <div id="success-feedback" class="hidden absolute inset-0 bg-zinc-950/95 rounded-2xl flex flex-col items-center justify-center text-center p-8 z-10 transition-all duration-500">
          <div class="h-12 w-12 rounded-full bg-brand-violet/10 text-brand-violet flex items-center justify-center mb-4">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-2 font-display">¡Solicitud Recibida Exitosamente!</h3>
          <p class="text-sm text-zinc-400 max-w-sm leading-relaxed mb-6">
            Nuestro equipo analizará tu consulta técnica y te contactará en menos de 24 horas para agendar tu diagnóstico gratuito.
          </p>
          <button 
            id="reset-form"
            class="text-xs font-semibold text-brand-violet hover:underline cursor-pointer"
          >
            Enviar otro mensaje
          </button>
        </div>
      </div>
    </div>

  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const successFeedback = document.getElementById('success-feedback');
  const resetBtn = document.getElementById('reset-form');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    // Simulate API Submission
    successFeedback?.classList.remove('hidden');
    form.reset();
  });

  resetBtn?.addEventListener('click', () => {
    successFeedback?.classList.add('hidden');
  });
</script>
