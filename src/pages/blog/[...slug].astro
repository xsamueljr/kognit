---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

// Generate dynamic routes for all posts in the collection
export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

// Retrieve post props
const { post } = Astro.props;
const { title, description, pubDate, author, image, tags } = post.data;
const imageWithPrefix = `/kognit/${image}`;

// Render markdown content to an Astro Component using the Astro v6 content layer render function
const { Content } = await render(post);
---

<Layout title={title} description={description}>
  <article class="relative py-8 sm:py-12 md:py-16 max-w-3xl mx-auto z-10">
    <!-- Subtle background blur details -->
    <div class="absolute -top-12 left-1/2 -translate-x-1/2 w-[300px] h-[300px] bg-brand-blue/5 blur-[80px] rounded-full pointer-events-none -z-10" aria-hidden="true"></div>

    <!-- Back Button -->
    <a 
      href="/kognit/blog" 
      class="inline-flex items-center gap-2 text-xs font-semibold text-zinc-500 hover:text-white transition-colors duration-300 mb-8 group"
    >
      <svg class="h-4 w-4 transition-transform duration-300 group-hover:-translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
      </svg>
      <span>Volver al Blog</span>
    </a>

    <!-- Article Header -->
    <header class="mb-10">
      <!-- Tags -->
      <div class="flex flex-wrap gap-2 mb-4">
        {tags.map((tag) => (
          <span class="text-[10px] font-bold text-brand-indigo uppercase tracking-widest bg-brand-indigo/10 px-2.5 py-0.5 rounded-full border border-brand-indigo/20">
            {tag}
          </span>
        ))}
      </div>

      <!-- Title -->
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight text-white mb-6 leading-tight font-display">
        {title}
      </h1>

      <!-- Description -->
      <p class="text-zinc-400 text-base sm:text-lg leading-relaxed mb-8">
        {description}
      </p>

      <!-- Author and Date Metadata -->
      <div class="flex items-center gap-4 border-t border-b border-white/[0.06] py-4 text-xs text-zinc-500 font-medium">
        <div class="flex items-center gap-2">
          <div class="h-6 w-6 rounded-full bg-zinc-800 border border-zinc-700 flex items-center justify-center text-[10px] text-zinc-400 font-mono">
            {author.charAt(0)}
          </div>
          <span class="text-zinc-300">{author}</span>
        </div>
        <span class="text-zinc-700">|</span>
        <time datetime={pubDate.toISOString()}>
          Publicado el {new Date(pubDate).toLocaleDateString('es-ES', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </time>
      </div>
    </header>

    <!-- Cover Image -->
    {image && (
      <div class="mb-12 rounded-2xl overflow-hidden border border-white/[0.08] bg-zinc-950 aspect-video shadow-2xl">
        <img 
          src={image} 
          alt={title} 
          class="w-full h-full object-cover"
        />
      </div>
    )}

    <!-- Article Content styled with Tailwind Typography -->
    <div class="prose prose-invert max-w-none prose-headings:font-display prose-headings:font-bold prose-headings:text-white prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-4 prose-p:leading-relaxed prose-p:text-zinc-300 prose-a:text-brand-violet prose-a:no-underline hover:prose-a:underline prose-strong:text-white prose-code:text-brand-cyan prose-code:bg-zinc-900 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:before:content-none prose-code:after:content-none prose-ul:list-disc prose-ul:pl-6 prose-li:my-2">
      <Content />
    </div>

    <!-- Final author/share detail -->
    <footer class="mt-16 pt-8 border-t border-white/[0.06] flex flex-col sm:flex-row items-center justify-between gap-6">
      <div class="flex items-center gap-3">
        <div class="h-10 w-10 rounded-full bg-zinc-800 border border-zinc-700 flex items-center justify-center text-sm text-zinc-300 font-mono font-bold">
          {author.charAt(0)}
        </div>
        <div>
          <div class="text-sm font-semibold text-white font-display">{author}</div>
          <div class="text-[11px] text-zinc-500">Colaborador en Transformación Digital — Kognit</div>
        </div>
      </div>
      
      <div>
        <a 
          href="/kognit/blog" 
          class="inline-flex items-center justify-center px-4 py-2 text-xs font-semibold text-zinc-400 hover:text-white transition-all duration-300 bg-zinc-950 border border-zinc-800 rounded-lg hover:border-zinc-700"
        >
          &larr; Volver al listado
        </a>
      </div>
    </footer>
  </article>
</Layout>
