---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import BlogCard from '../../components/BlogCard.astro';

// Fetch all markdown posts inside src/content/blog/
const posts = await getCollection('blog');

// Sort posts chronologically: most recent first
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout 
  title="Blog Técnico" 
  description="Ideas, guías y casos de estudio sobre automatización con IA, digitalización empresarial y desarrollo web premium. Mantente a la vanguardia de la tecnología B2B."
>
  <div class="relative py-8 sm:py-12 md:py-16">
    <!-- Glowing background elements -->
    <div class="absolute -top-12 left-1/2 -translate-x-1/2 w-[350px] sm:w-[600px] h-[350px] bg-brand-violet/5 blur-[100px] rounded-full pointer-events-none -z-10" aria-hidden="true"></div>

    <!-- Header Section -->
    <div class="max-w-3xl mb-16 text-left border-b border-white/[0.06] pb-10">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-white/[0.08] bg-zinc-950/80 backdrop-blur-sm mb-4">
        <span class="flex h-1.5 w-1.5 rounded-full bg-brand-violet animate-pulse"></span>
        <span class="text-[10px] font-bold text-zinc-300 uppercase tracking-widest font-mono">Artículos & Recursos</span>
      </div>
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-white mb-4 font-display">
        Blog Técnico de Kognit
      </h1>
      <p class="text-zinc-400 text-base sm:text-lg leading-relaxed">
        Compartimos nuestro conocimiento técnico sobre automatización avanzada, integraciones de IA, bases de datos vectoriales y desarrollo web moderno.
      </p>
    </div>

    <!-- Blog Grid -->
    {sortedPosts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-10">
        {sortedPosts.map((post) => (
          <BlogCard post={post} />
        ))}
      </div>
    ) : (
      <div class="border border-white/[0.06] bg-zinc-950/30 rounded-2xl p-12 text-center">
        <svg class="mx-auto h-12 w-12 text-zinc-700 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 01-2.25 2.25M16.5 7.5V18a2.25 2.25 0 002.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 002.25 2.25h13.5M6 7.5h3v3H6v-3z" />
        </svg>
        <h3 class="text-lg font-bold text-white mb-2 font-display">No hay artículos publicados</h3>
        <p class="text-zinc-500 text-sm max-w-sm mx-auto">Pronto publicaremos nuevo contenido sobre transformación digital e Inteligencia Artificial.</p>
      </div>
    )}
  </div>
</Layout>
