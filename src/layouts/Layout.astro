---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { 
  title, 
  description = "Kognit - Agencia B2B de transformación digital, automatización de procesos con IA y desarrollo web a medida de rendimiento ultra rápido." 
} = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Primary Meta Tags -->
    <title>{title} | Kognit - Transformación Digital & IA</title>
    <meta name="title" content={`${title} | Kognit - Transformación Digital & IA`} />
    <meta name="description" content={description} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={`${title} | Kognit`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/images/og-image.jpg" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={`${title} | Kognit`} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content="/images/og-image.jpg" />
  </head>
  <body class="bg-black text-zinc-400 font-sans selection:bg-brand-indigo/30 selection:text-white antialiased">
    <!-- Background Grid overlay -->
    <div class="fixed inset-0 bg-grid-pattern pointer-events-none z-0" aria-hidden="true"></div>
    <!-- Radial ambient glows -->
    <div class="fixed top-0 left-1/2 -translate-x-1/2 w-full max-w-7xl h-[600px] bg-glow-radial pointer-events-none z-0" aria-hidden="true"></div>
    
    <header class="sticky top-0 z-50 w-full border-b border-white/[0.06] bg-black/60 backdrop-blur-md">
      <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-6 sm:px-8">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2 group z-50">
          <div class="relative flex h-9 w-9 items-center justify-center rounded-lg border border-white/10 bg-zinc-950 transition-all duration-300 group-hover:border-brand-indigo/50">
            <span class="text-lg font-bold text-white font-display select-none">K</span>
            <!-- Ambient dot decoration inside icon -->
            <span class="absolute bottom-1 right-1 h-1.5 w-1.5 rounded-full bg-brand-indigo animate-pulse"></span>
          </div>
          <span class="text-xl font-bold tracking-tight text-white font-display transition-all duration-300 group-hover:text-zinc-200">
            Kognit<span class="text-brand-indigo font-display">.</span>
          </span>
        </a>

        <!-- Desktop Navigation -->
        <nav class="hidden md:flex items-center gap-8">
          <a href="/#servicios" class="text-sm font-medium text-zinc-400 transition-colors duration-300 hover:text-white">Servicios</a>
          <a href="/#beneficios" class="text-sm font-medium text-zinc-400 transition-colors duration-300 hover:text-white">Beneficios</a>
          <a href="/blog" class="text-sm font-medium text-zinc-400 transition-colors duration-300 hover:text-white">Blog</a>
          <a href="/#contacto" class="text-sm font-medium text-zinc-400 transition-colors duration-300 hover:text-white">Contacto</a>
        </nav>

        <!-- Navbar Action Button -->
        <div class="hidden md:flex items-center gap-4">
          <a 
            href="/#contacto" 
            class="relative inline-flex items-center justify-center px-4 py-2 text-xs font-semibold tracking-wide text-white transition-all duration-300 bg-zinc-950 border border-zinc-800 rounded-lg hover:border-zinc-700 hover:bg-zinc-900 group"
          >
            <span>Optimiza tu Empresa</span>
            <svg class="w-3 h-3 ml-1.5 transition-transform duration-300 group-hover:translate-x-0.5 text-zinc-400 group-hover:text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </div>

        <!-- Mobile Menu Trigger -->
        <button 
          id="mobile-menu-toggle"
          class="flex md:hidden h-10 w-10 items-center justify-center rounded-lg border border-zinc-800 bg-zinc-950 text-white transition-all duration-300 hover:border-zinc-700 active:scale-95 z-50"
          aria-label="Abrir menú"
        >
          <svg id="menu-icon-open" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
          <svg id="menu-icon-close" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <!-- Mobile Dropdown Navigation -->
      <div 
        id="mobile-menu" 
        class="hidden fixed inset-0 top-[64px] z-40 w-full bg-black/95 backdrop-blur-lg border-t border-white/[0.06] transition-all duration-300"
      >
        <div class="flex flex-col gap-6 p-8">
          <a href="/#servicios" class="mobile-nav-link text-lg font-medium text-zinc-300 hover:text-white transition-colors duration-300">Servicios</a>
          <a href="/#beneficios" class="mobile-nav-link text-lg font-medium text-zinc-300 hover:text-white transition-colors duration-300">Beneficios</a>
          <a href="/blog" class="mobile-nav-link text-lg font-medium text-zinc-300 hover:text-white transition-colors duration-300">Blog</a>
          <a href="/#contacto" class="mobile-nav-link text-lg font-medium text-zinc-300 hover:text-white transition-colors duration-300">Contacto</a>
          
          <div class="h-px bg-zinc-800 my-2"></div>
          
          <a 
            href="/#contacto" 
            class="mobile-nav-link w-full py-3.5 text-center text-sm font-semibold text-white bg-brand-indigo rounded-lg hover:bg-brand-indigo/90 transition-all duration-300 shadow-[0_0_20px_rgba(99,102,241,0.2)]"
          >
            Optimiza tu Empresa
          </a>
        </div>
      </div>
    </header>

    <!-- Main Content Area -->
    <main class="relative z-10 mx-auto max-w-7xl px-6 sm:px-8 py-12 md:py-20 lg:py-24 min-h-[calc(100vh-280px)]">
      <slot />
    </main>

    <!-- Footer component -->
    <footer class="relative z-10 border-t border-white/[0.06] bg-black py-16 md:py-20">
      <div class="mx-auto max-w-7xl px-6 sm:px-8">
        <div class="grid grid-cols-1 gap-10 md:grid-cols-4 lg:gap-16">
          <div class="md:col-span-2">
            <a href="/" class="flex items-center gap-2 group mb-6">
              <div class="flex h-9 w-9 items-center justify-center rounded-lg border border-white/10 bg-zinc-950 transition-all duration-300 group-hover:border-brand-indigo/50">
                <span class="text-lg font-bold text-white font-display">K</span>
              </div>
              <span class="text-xl font-bold tracking-tight text-white font-display">Kognit<span class="text-brand-indigo font-display">.</span></span>
            </a>
            <p class="max-w-sm text-sm leading-relaxed text-zinc-500">
              Transformamos negocios mediante automatización inteligente con Inteligencia Artificial, digitalización de flujos de trabajo B2B y desarrollo de software de alto rendimiento.
            </p>
          </div>
          <div>
            <h3 class="mb-4 text-sm font-semibold tracking-wider text-white uppercase font-display">Compañía</h3>
            <ul class="space-y-3 text-sm">
              <li><a href="/#servicios" class="text-zinc-500 transition-colors duration-300 hover:text-white">Servicios</a></li>
              <li><a href="/#beneficios" class="text-zinc-500 transition-colors duration-300 hover:text-white">Beneficios</a></li>
              <li><a href="/blog" class="text-zinc-500 transition-colors duration-300 hover:text-white">Blog Técnico</a></li>
            </ul>
          </div>
          <div>
            <h3 class="mb-4 text-sm font-semibold tracking-wider text-white uppercase font-display">Contacto</h3>
            <ul class="space-y-3 text-sm">
              <li class="text-zinc-500">info@kognit.ai</li>
              <li class="text-zinc-500">Madrid, España</li>
              <li><a href="/#contacto" class="inline-flex items-center text-brand-indigo hover:text-brand-indigo/80 transition-colors duration-300 font-medium">Trabaja con nosotros &rarr;</a></li>
            </ul>
          </div>
        </div>
        
        <div class="mt-12 md:mt-16 border-t border-white/[0.06] pt-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-zinc-600">
          <p>&copy; {new Date().getFullYear()} Kognit AI. Todos los derechos reservados.</p>
          <div class="flex gap-6">
            <a href="#" class="hover:text-zinc-400 transition-colors">Aviso Legal</a>
            <a href="#" class="hover:text-zinc-400 transition-colors">Privacidad</a>
            <a href="#" class="hover:text-zinc-400 transition-colors">Cookies</a>
          </div>
        </div>
      </div>
    </footer>

    <!-- Mobile Menu Script -->
    <script>
      const toggleBtn = document.getElementById('mobile-menu-toggle');
      const mobileMenu = document.getElementById('mobile-menu');
      const openIcon = document.getElementById('menu-icon-open');
      const closeIcon = document.getElementById('menu-icon-close');
      const mobileLinks = document.querySelectorAll('.mobile-nav-link');

      function toggleMenu() {
        mobileMenu?.classList.toggle('hidden');
        openIcon?.classList.toggle('hidden');
        closeIcon?.classList.toggle('hidden');
        document.body.classList.toggle('overflow-hidden');
      }

      toggleBtn?.addEventListener('click', toggleMenu);

      mobileLinks.forEach(link => {
        link.addEventListener('click', () => {
          mobileMenu?.classList.add('hidden');
          openIcon?.classList.remove('hidden');
          closeIcon?.classList.add('hidden');
          document.body.classList.remove('overflow-hidden');
        });
      });
    </script>
  </body>
</html>
